{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thepantry.local/schemas/recipe.schema.json",
  "title": "The Pantry App Recipe Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "recipeVersion",
    "catalog",
    "preferredProvider",
    "source",
    "trustLevel",
    "scopePreference",
    "administratorRequirement",
    "dependencies",
    "conflicts",
    "expectedExitCodes",
    "rebootBehavior",
    "detection",
    "update",
    "uninstall",
    "verification"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "recipeVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "shortDescription",
        "category",
        "homepage",
        "isPortable"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "shortDescription": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "isPortable": {
          "type": "boolean"
        }
      }
    },
    "preferredProvider": {
      "$ref": "#/$defs/providerType"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "identifier",
        "officialUrl"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/providerType"
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "officialUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "trustLevel": {
      "type": "string",
      "enum": [
        "VerifiedUnattended",
        "VerifiedGuided",
        "ManualOfficial",
        "Experimental",
        "Blocked"
      ]
    },
    "scopePreference": {
      "type": "string",
      "enum": [
        "NotApplicable",
        "NotSupported",
        "Preferred",
        "Required"
      ]
    },
    "administratorRequirement": {
      "type": "string",
      "enum": [
        "NotRequired",
        "Required",
        "Unknown"
      ]
    },
    "portableDestinationHint": {
      "type": [
        "string",
        "null"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "expectedExitCodes": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "rebootBehavior": {
      "type": "string",
      "enum": [
        "NeverAutomatic",
        "MayRequireManualReboot",
        "Unknown"
      ]
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rules",
        "minimumConfidence"
      ],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "minimumConfidence": {
          "type": "string",
          "enum": [
            "High",
            "Medium",
            "Low"
          ]
        }
      }
    },
    "update": {
      "$ref": "#/$defs/recipeAction"
    },
    "uninstall": {
      "$ref": "#/$defs/recipeAction"
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifiedOn",
        "evidence"
      ],
      "properties": {
        "verifiedOn": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "providerType": {
      "type": "string",
      "enum": [
        "Winget",
        "MicrosoftStore",
        "OfficialMsi",
        "OfficialExe",
        "OfficialGitHubRelease",
        "PortableArchive",
        "ManualOfficial"
      ]
    },
    "recipeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "supported"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "supported": {
          "type": "boolean"
        }
      }
    }
  }
}

