<Application x:Class="DevToolsCurator.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DevToolsCurator.App">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0F17" />
        <SolidColorBrush x:Key="AppPanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="AppPanelAltBrush" Color="#172033" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="AppMutedTextBrush" Color="#9AA6B2" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#58A6FF" />

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Padding" Value="10,7" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263750" />
                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#64748B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263750" />
                    <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#64748B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="#0B1220" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AppTextBrush}" />
            <Setter Property="SelectionBrush" Value="#2563EB" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="Padding" Value="10" />
        </Style>
    </Application.Resources>
</Application>
