<Window x:Class="DevToolsCurator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:DevToolsCurator.App"
        Title="Windows DevTools Curator"
        Height="840"
        Width="1320"
        MinHeight="720"
        MinWidth="1040"
        Background="#0B0F17"
        Foreground="#E6EDF3"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <app:ViewVisibilityConverter x:Key="ViewVisibility" />
        <app:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <app:InverseBoolConverter x:Key="InverseBool" />
        <app:StatusBrushConverter x:Key="StatusBrush" />
        <app:StatusIconConverter x:Key="StatusIcon" />

        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#172033" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#263244" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9AA6B2" />
        <SolidColorBrush x:Key="AccentBrush" Color="#58A6FF" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E6EDF3" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#263750" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#3B82F6" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,14,14" />
        </Style>

        <DataTemplate x:Key="ToolRowTemplate">
            <Border Background="#101826"
                    BorderBrush="#263244"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,0,8"
                    Padding="12"
                    PreviewMouseLeftButtonDown="ToolRow_OnMouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusIcon}}"
                                   Foreground="#081018"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="6,0,16,0">
                        <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Tool.Description}" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding Status, Converter={StaticResource StatusBrush}}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Version}" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,16,0">
                        <TextBlock Text="{Binding DetectedPath}" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding DetectionSource}" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="4" VerticalAlignment="Center">
                        <Button Content="Install"
                                Visibility="{Binding CanInstall, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding DataContext.InstallToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Install this missing tool." />
                        <Button Content="Update"
                                Visibility="{Binding CanUpdate, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding DataContext.UpdateToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Update this installed tool." />
                        <Button Content="Repair"
                                Visibility="{Binding CanRepair, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding DataContext.RepairToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Repair this broken tool through the configured backend." />
                        <Button Content="Fix PATH"
                                Visibility="{Binding CanFixPath, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding DataContext.FixPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Add the detected install directory to user PATH after confirmation." />
                        <Button Content="Open"
                                Visibility="{Binding CanOpen, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding DataContext.OpenToolCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Open the detected install folder." />
                        <Button Content="Info"
                                Command="{Binding DataContext.ShowInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Show clean tool details and troubleshooting." />
                    </WrapPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A" BorderBrush="#1F2937" BorderThickness="0,0,1,0" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="DevTools" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Curator" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,18" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                    <ProgressBar Height="4" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,28,0,0">
                    <Button Style="{StaticResource NavButton}" Content="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" />
                    <Button Style="{StaticResource NavButton}" Content="Wizard" Command="{Binding StartWizardCommand}" />
                    <Button Style="{StaticResource NavButton}" Content="Tools" Command="{Binding NavigateCommand}" CommandParameter="Tools" />
                    <Button Style="{StaticResource NavButton}" Content="Updates" Command="{Binding NavigateCommand}" CommandParameter="Updates" />
                    <Button Style="{StaticResource NavButton}" Content="Issues" Command="{Binding NavigateCommand}" CommandParameter="Issues" />
                    <Button Style="{StaticResource NavButton}" Content="Reports" Command="{Binding NavigateCommand}" CommandParameter="Reports" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentView}" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="Accurate Windows 11 developer-environment detection, guidance, and safe installs." Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Export Summary" Command="{Binding ExportSummaryCommand}" HorizontalAlignment="Right" />
            </DockPanel>

            <Grid Grid.Row="1">
                <ScrollViewer Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibility}, ConverterParameter=Dashboard}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Cards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                            <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="Bold" Margin="0,7,0,4" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="One-click Actions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <WrapPanel>
                                    <Button Style="{StaticResource PrimaryButton}" Content="Start Wizard" Command="{Binding StartWizardCommand}" />
                                    <Button Content="Install Recommended" Command="{Binding InstallRecommendedCommand}" />
                                    <Button Content="Update Installed" Command="{Binding UpdateInstalledCommand}" />
                                    <Button Content="Repair Issues" Command="{Binding RepairIssuesCommand}" />
                                    <Button Content="Rescan" Command="{Binding RescanCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Selected Tool" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedToolDetails}" Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibility}, ConverterParameter=Tools}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Margin="0,0,14,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ToolFilter, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#0B1220"
                                             Foreground="#E6EDF3"
                                             BorderBrush="#334155"
                                             Padding="10"
                                             FontSize="14" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding ToolFilterModes}"
                                              SelectedItem="{Binding ToolFilterMode, Mode=TwoWay}"
                                              Margin="12,0,0,0"
                                              Background="#111827"
                                              Foreground="#E6EDF3"
                                              Padding="8" />
                                    <Button Grid.Column="2" Content="Rescan" Command="{Binding RescanCommand}" Margin="12,0,0,0" />
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding ToolGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Header="{Binding Name}" IsExpanded="True" Foreground="#E6EDF3" Margin="0,0,14,12">
                                            <ItemsControl ItemsSource="{Binding Tools}" ItemTemplate="{StaticResource ToolRowTemplate}" />
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Details" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedToolDetails}" Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                            <Button Content="Copy Diagnostics" Command="{Binding CopyDiagnosticsCommand}" Margin="0,16,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibility}, ConverterParameter=Updates}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Updates Available" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="Only installed tools with a known update path appear here." Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,16" />
                                <Button Content="Update Installed" Command="{Binding UpdateInstalledCommand}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Updates}" ItemTemplate="{StaticResource ToolRowTemplate}" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibility}, ConverterParameter=Issues}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Issues To Fix" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="Missing recommended tools, PATH issues, broken validations, auth actions, and reboot signals." Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,16" />
                                <WrapPanel>
                                    <Button Content="Repair Issues" Command="{Binding RepairIssuesCommand}" />
                                    <Button Content="Copy Diagnostics" Command="{Binding CopyDiagnosticsCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Issues}" ItemTemplate="{StaticResource ToolRowTemplate}" />
                        <ItemsControl ItemsSource="{Binding IssueMessages}" Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibility}, ConverterParameter=Reports}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Reports" FontSize="22" FontWeight="Bold" />
                                <TextBlock Text="Creates summary.md, tools.csv, issues.json, install_plan.json, last_scan.json, and repair_suggestions.md." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,18" TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Button Style="{StaticResource PrimaryButton}" Content="Export Summary" Command="{Binding ExportSummaryCommand}" />
                                    <Button Content="Open Report Folder" Command="{Binding OpenReportFolderCommand}" />
                                    <Button Content="Run UI Self Check" Command="{Binding RunUiSelfCheckCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Action Results" FontSize="18" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding EventStream}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,4" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
