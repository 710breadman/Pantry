<Window x:Class="DevToolsCurator.App.ToolInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DisplayName}"
        Width="640"
        Height="620"
        MinWidth="560"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#0B0F17"
        Foreground="#E6EDF3">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#263244" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9AA6B2" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E6EDF3" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding DisplayName}" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="0,6,0,18" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="What it is" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Why useful" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{Binding WhyUseful}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Detected" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{Binding Detected}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Actions" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{Binding AvailableActions}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Troubleshooting" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="{Binding TroubleshootingNotes}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
