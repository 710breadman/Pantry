<Window x:Class="DevToolsCurator.App.WizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:DevToolsCurator.App"
        Title="Setup Wizard"
        Width="760"
        Height="680"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#0B0F17"
        Foreground="#E6EDF3">
    <Window.Resources>
        <app:IntEqualsVisibilityConverter x:Key="StepVisibility" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#263244" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9AA6B2" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E6EDF3" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#3B82F6" />
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Developer Setup Wizard" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="{Binding StepLabel}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,12" />
            <ProgressBar Minimum="0" Maximum="4" Value="{Binding StepIndex}" Height="5" />
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,18,0,18">
            <Grid>
                <StackPanel Visibility="{Binding StepIndex, Converter={StaticResource StepVisibility}, ConverterParameter=0}">
                    <TextBlock Text="What do you want to build?" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Choose the closest profile. You can refine it in later steps." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,14" />
                    <ListBox ItemsSource="{Binding Profiles}" SelectedValue="{Binding SelectedGoalId, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Name" />
                </StackPanel>

                <StackPanel Visibility="{Binding StepIndex, Converter={StaticResource StepVisibility}, ConverterParameter=1}">
                    <TextBlock Text="Preferred languages" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Pick any languages you expect to use. Undecided is fine." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,14" />
                    <ItemsControl ItemsSource="{Binding Languages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Foreground="#E6EDF3" Width="210" Margin="0,0,12,12" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Visibility="{Binding StepIndex, Converter={StaticResource StepVisibility}, ConverterParameter=2}">
                    <TextBlock Text="Install depth" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Recommended is the default: useful without dragging in large optional stacks." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,14" />
                    <ComboBox ItemsSource="{Binding InstallStyles}" SelectedItem="{Binding InstallStyle, Mode=TwoWay}" />
                    <TextBlock Text="Update behavior" FontWeight="SemiBold" Margin="0,22,0,8" />
                    <ComboBox ItemsSource="{Binding UpdateBehaviors}" SelectedItem="{Binding UpdateBehavior, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Visibility="{Binding StepIndex, Converter={StaticResource StepVisibility}, ConverterParameter=3}">
                    <TextBlock Text="Heavy tools permission" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="These are useful, but large or system-changing. They will not install unless allowed." Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,14" />
                    <CheckBox Content="Android Studio" IsChecked="{Binding AllowAndroidStudio, Mode=TwoWay}" Foreground="#E6EDF3" Margin="0,0,0,10" />
                    <CheckBox Content="Docker Desktop" IsChecked="{Binding AllowDockerDesktop, Mode=TwoWay}" Foreground="#E6EDF3" Margin="0,0,0,10" />
                    <CheckBox Content="WSL2" IsChecked="{Binding AllowWsl2, Mode=TwoWay}" Foreground="#E6EDF3" Margin="0,0,0,10" />
                    <CheckBox Content="Visual Studio Community" IsChecked="{Binding AllowVisualStudioCommunity, Mode=TwoWay}" Foreground="#E6EDF3" Margin="0,0,0,10" />
                    <CheckBox Content="Full Visual Studio Build Tools workloads" IsChecked="{Binding AllowVisualStudioBuildTools, Mode=TwoWay}" Foreground="#E6EDF3" Margin="0,0,0,10" />
                </StackPanel>

                <ScrollViewer Visibility="{Binding StepIndex, Converter={StaticResource StepVisibility}, ConverterParameter=4}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Review plan" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WarningText}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,14" TextWrapping="Wrap" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Required" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RequiredTools}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,14" />
                                <TextBlock Text="Already installed / detected" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding InstalledTools}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Recommended" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RecommendedTools}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,14" />
                                <TextBlock Text="Missing / needs action" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MissingTools}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,14" />
                                <TextBlock Text="Optional skipped" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding OptionalTools}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back" Command="{Binding BackCommand}" />
                <Button Content="Next" Command="{Binding NextCommand}" />
                <Button Content="Save Plan" Command="{Binding FinishCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Apply Recommended" Command="{Binding ApplyRecommendedCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
